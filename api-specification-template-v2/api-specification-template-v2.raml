#%RAML 1.0

# =============================================================================
# MÉTA-INFORMATIONS - Conformes aux meilleures pratiques MuleSoft
# =============================================================================

title: API Specification Template v2
description: |
  Template d'API conforme aux meilleures pratiques MuleSoft pour la gouvernance d'API.
  Cette spécification sert de modèle de référence pour développer des APIs robustes,
  sécurisées et bien documentées selon les standards organisationnels.

version: v2.0.0
mediaType: application/json

# Informations de contact et licence dans la documentation
# (contact et license ne sont pas supportés directement en RAML 1.0)

# Documentation obligatoire
documentation:
  - title: Guide de démarrage
    content: |
      ## Présentation
      Cette API template fournit un exemple complet d'implémentation des meilleures pratiques MuleSoft.
      
      ## Authentification
      L'API utilise OAuth 2.0 Bearer Token pour l'authentification.
      
      ## Limitation de taux
      - 1000 requêtes par heure par client
      - Headers X-RateLimit-* pour le monitoring
      
      ## Gestion d'erreur
      Toutes les erreurs suivent le format standardisé ErrorResponse avec codes structurés.

  - title: Exemples d'utilisation
    content: |
      ## Création d'une ressource
      ```
      POST /customers
      Authorization: Bearer {token}
      Content-Type: application/json
      
      {
        "name": "John Doe",
        "email": "john.doe@example.com"
      }
      ```
      
      ## Récupération avec pagination
      ```
      GET /customers?offset=0&limit=20&sort=name:asc
      Authorization: Bearer {token}
      ```

# =============================================================================
# IMPORTS DE LA BIBLIOTHÈQUE COMMUNE
# =============================================================================

uses:
  common: ../api-common-library-v2/api-common-library-v2.raml

# =============================================================================
# TYPES DE DONNÉES MÉTIER
# =============================================================================

types:
  # Entité Customer exemple
  Customer:
    type: object
    properties:
      id:
        type: common.UUID
        description: Identifiant unique du client
      name:
        type: string
        minLength: 2
        maxLength: 100
        description: Nom complet du client
        example: "Jean Dupont"
      email:
        type: string
        pattern: ^[^\s@]+@[^\s@]+\.[^\s@]+$
        description: Adresse email du client
        example: "jean.dupont@example.com"
      phone?:
        type: string
        pattern: ^\+33[1-9](?:[0-9]{8})$
        description: Numéro de téléphone français
        example: "+33123456789"
      address?:
        type: common.Address
        description: Adresse du client
      status:
        type: string
        enum: [active, inactive, suspended]
        default: active
        description: Statut du client
      metadata:
        type: common.Metadata
        description: Métadonnées d'audit
    example:
      id: "123e4567-e89b-12d3-a456-426614174000"
      name: "Jean Dupont"
      email: "jean.dupont@example.com"
      phone: "+33123456789"
      address:
        street: "123 Rue de la République"
        city: "Paris"
        postalCode: "75001"
        country: "FR"
      status: "active"
      metadata:
        createdAt: "2024-01-15T10:30:00Z"
        updatedAt: "2024-01-15T10:30:00Z"
        createdBy: "admin"
        version: 1

  # DTO pour création/mise à jour
  CustomerRequest:
    type: object
    properties:
      name:
        type: string
        minLength: 2
        maxLength: 100
        description: Nom complet du client
        example: "Jean Dupont"
      email:
        type: string
        pattern: ^[^\s@]+@[^\s@]+\.[^\s@]+$
        description: Adresse email du client
        example: "jean.dupont@example.com"
      phone?:
        type: string
        pattern: ^\+33[1-9](?:[0-9]{8})$
        description: Numéro de téléphone français
        example: "+33123456789"
      address?:
        type: common.Address
        description: Adresse du client
      status?:
        type: string
        enum: [active, inactive, suspended]
        default: active
        description: Statut du client
    example:
      name: "Jean Dupont"
      email: "jean.dupont@example.com"
      phone: "+33123456789"
      address:
        street: "123 Rue de la République"
        city: "Paris"
        postalCode: "75001"
        country: "FR"
      status: "active"

  # Réponse collection avec pagination
  CustomersResponse:
    type: object
    properties:
      data:
        type: Customer[]
        description: Liste des clients
      pagination:
        type: common.PaginationResponse
        description: Informations de pagination
    example:
      data:
        - id: "123e4567-e89b-12d3-a456-426614174000"
          name: "Jean Dupont"
          email: "jean.dupont@example.com"
          status: "active"
          metadata:
            createdAt: "2024-01-15T10:30:00Z"
            updatedAt: "2024-01-15T10:30:00Z"
            version: 1
      pagination:
        offset: 0
        limit: 20
        total: 150
        count: 1

  # Type pour patch partiel
  CustomerPatch:
    type: object
    properties:
      name?:
        type: string
        minLength: 2
        maxLength: 100
        description: Nouveau nom du client
      email?:
        type: string
        pattern: ^[^\s@]+@[^\s@]+\.[^\s@]+$
        description: Nouvelle adresse email
      phone?:
        type: string
        pattern: ^\+33[1-9](?:[0-9]{8})$
        description: Nouveau numéro de téléphone
      address?:
        type: common.Address
        description: Nouvelle adresse
      status?:
        type: string
        enum: [active, inactive, suspended]
        description: Nouveau statut
    example:
      status: "inactive"

# =============================================================================
# DÉFINITION DES ENDPOINTS
# =============================================================================

# Collection de clients
/customers:
  description: Gestion de la collection des clients
  
  # Récupération de la liste des clients
  get:
    displayName: Lister les clients
    description: |
      Récupère la liste paginée des clients avec possibilité de tri et filtrage.
      Supporte la pagination, le tri multi-critères et le filtrage flexible.
    
    # Application des traits de gouvernance
    is: 
      - common.oauth2Protected
      - common.rateLimited  
      - common.paginated
      - common.sortable
      - common.filterable
      - common.traceable
      - common.cacheable
      - common.standardResponses
    
    # Paramètres de requête spécifiques
    queryParameters:
      status?:
        description: Filtrer par statut
        type: string
        enum: [active, inactive, suspended]
        example: active
      search?:
        description: Recherche textuelle dans le nom et l'email
        type: string
        minLength: 2
        example: "jean"
    
    # Réponses
    responses:
      200:
        description: Liste des clients récupérée avec succès
        headers:
          X-Total-Count:
            description: Nombre total de clients
            type: integer
            example: 150
          Cache-Control:
            description: Directives de cache
            type: string
            example: "public, max-age=300"
        body:
          application/json:
            type: CustomersResponse
            example:
              data:
                - id: "123e4567-e89b-12d3-a456-426614174000"
                  name: "Jean Dupont"
                  email: "jean.dupont@example.com"
                  status: "active"
                  metadata:
                    createdAt: "2024-01-15T10:30:00Z"
                    updatedAt: "2024-01-15T10:30:00Z"
                    version: 1
              pagination:
                offset: 0
                limit: 20
                total: 150
                count: 1

  # Création d'un nouveau client
  post:
    displayName: Créer un client
    description: |
      Crée un nouveau client dans le système.
      Valide les données d'entrée et génère automatiquement l'identifiant unique.
    
    # Application des traits de gouvernance
    is: 
      - common.oauth2Protected
      - common.rateLimited
      - common.traceable
      - common.standardResponses
    
    # Corps de la requête
    body:
      application/json:
        type: CustomerRequest
        example:
          name: "Marie Martin"
          email: "marie.martin@example.com"
          phone: "+33987654321"
          address:
            street: "456 Avenue des Champs"
            city: "Lyon"
            postalCode: "69001"
            country: "FR"
    
    # Réponses
    responses:
      201:
        description: Client créé avec succès
        headers:
          Location:
            description: URL du client créé
            type: string
            example: "/customers/123e4567-e89b-12d3-a456-426614174000"
        body:
          application/json:
            type: Customer
            example:
              id: "123e4567-e89b-12d3-a456-426614174000"
              name: "Marie Martin"
              email: "marie.martin@example.com"
              phone: "+33987654321"
              address:
                street: "456 Avenue des Champs"
                city: "Lyon"
                postalCode: "69001"
                country: "FR"
              status: "active"
              metadata:
                createdAt: "2024-01-15T10:30:00Z"
                updatedAt: "2024-01-15T10:30:00Z"
                createdBy: "api-user"
                version: 1
      409:
        description: Conflit - Client avec cet email existe déjà
        body:
          application/json:
            type: common.ErrorResponse
            example:
              error:
                code: "CONFLICT"
                message: "Un client avec cet email existe déjà"
                details:
                  - code: "EMAIL_ALREADY_EXISTS"
                    message: "L'email marie.martin@example.com est déjà utilisé"
                    field: "email"
                    value: "marie.martin@example.com"
                    timestamp: "2024-01-15T10:30:00Z"
                timestamp: "2024-01-15T10:30:00Z"

# Client individuel
/customers/{customerId}:
  description: Gestion d'un client spécifique
  
  # Paramètres d'URI
  uriParameters:
    customerId:
      description: Identifiant unique du client
      type: common.UUID
      example: "123e4567-e89b-12d3-a456-426614174000"
  
  # Récupération d'un client
  get:
    displayName: Récupérer un client
    description: |
      Récupère les détails complets d'un client spécifique.
      Supporte la mise en cache conditionnelle via ETag.
    
    # Application des traits de gouvernance
    is: 
      - common.oauth2Protected
      - common.rateLimited
      - common.traceable
      - common.cacheable
      - common.conditionalRequest
      - common.standardResponses
    
    # Réponses
    responses:
      200:
        description: Détails du client récupérés avec succès
        headers:
          ETag:
            description: Version du client pour cache conditionnel
            type: string
            example: '"v1-123e4567"'
          Last-Modified:
            description: Date de dernière modification
            type: datetime
            format: rfc2616
            example: "Wed, 15 Jan 2024 10:30:00 GMT"
        body:
          application/json:
            type: Customer
            example:
              id: "123e4567-e89b-12d3-a456-426614174000"
              name: "Jean Dupont"
              email: "jean.dupont@example.com"
              phone: "+33123456789"
              status: "active"
              metadata:
                createdAt: "2024-01-15T10:30:00Z"
                updatedAt: "2024-01-15T10:30:00Z"
                version: 1

  # Mise à jour complète d'un client
  put:
    displayName: Mettre à jour un client
    description: |
      Met à jour complètement un client existant.
      Utilise la gestion de concurrence optimiste avec ETag.
    
    # Application des traits de gouvernance
    is: 
      - common.oauth2Protected
      - common.rateLimited
      - common.traceable
      - common.conditionalRequest
      - common.standardResponses
    
    # Corps de la requête
    body:
      application/json:
        type: CustomerRequest
        example:
          name: "Jean Dupont-Martin"
          email: "jean.dupont-martin@example.com"
          phone: "+33123456789"
          status: "active"
    
    # Réponses
    responses:
      200:
        description: Client mis à jour avec succès
        headers:
          ETag:
            description: Nouvelle version du client
            type: string
            example: '"v2-123e4567"'
        body:
          application/json:
            type: Customer
            example:
              id: "123e4567-e89b-12d3-a456-426614174000"
              name: "Jean Dupont-Martin"
              email: "jean.dupont-martin@example.com"
              phone: "+33123456789"
              status: "active"
              metadata:
                createdAt: "2024-01-15T10:30:00Z"
                updatedAt: "2024-01-15T11:00:00Z"
                updatedBy: "api-user"
                version: 2

  # Mise à jour partielle d'un client
  patch:
    displayName: Modifier partiellement un client
    description: |
      Modifie partiellement un client existant.
      Seuls les champs fournis sont mis à jour.
    
    # Application des traits de gouvernance
    is: 
      - common.oauth2Protected
      - common.rateLimited
      - common.traceable
      - common.conditionalRequest
      - common.standardResponses
    
    # Corps de la requête
    body:
      application/json:
        type: CustomerPatch
        example:
          status: "inactive"
    
    # Réponses
    responses:
      200:
        description: Client modifié avec succès
        headers:
          ETag:
            description: Nouvelle version du client
            type: string
            example: '"v3-123e4567"'
        body:
          application/json:
            type: Customer

  # Suppression d'un client
  delete:
    displayName: Supprimer un client
    description: |
      Supprime définitivement un client du système.
      Cette action est irréversible.
    
    # Application des traits de gouvernance
    is: 
      - common.oauth2Protected
      - common.rateLimited
      - common.traceable
      - common.conditionalRequest
      - common.standardResponses
    
    # Paramètres de requête
    queryParameters:
      force?:
        description: Forcer la suppression même si le client a des références
        type: boolean
        default: false
        example: false
    
    # Réponses
    responses:
      204:
        description: Client supprimé avec succès
      409:
        description: Impossible de supprimer - Client référencé
        body:
          application/json:
            type: common.ErrorResponse
            example:
              error:
                code: "CONFLICT"
                message: "Impossible de supprimer le client car il a des références actives"
                timestamp: "2024-01-15T10:30:00Z"

# =============================================================================
# ENDPOINTS DE SANTÉ ET MONITORING (Conformes aux meilleures pratiques)
# =============================================================================

# Endpoint de santé de l'API
/health:
  description: Point de contrôle de santé de l'API
  
  get:
    displayName: Vérifier la santé
    description: |
      Vérifie l'état de santé de l'API et de ses dépendances.
      Utilisé par les systèmes de monitoring et load balancers.
    
    # Pas d'authentification pour les health checks
    is:
      - common.traceable
    
    responses:
      200:
        description: API en bonne santé
        body:
          application/json:
            type: object
            properties:
              status:
                type: string
                enum: [healthy, degraded, unhealthy]
              timestamp:
                type: common.DateTime
              version:
                type: string
              dependencies:
                type: object
                properties:
                  database:
                    type: string
                    enum: [healthy, unhealthy]
                  cache:
                    type: string
                    enum: [healthy, unhealthy]
            example:
              status: "healthy"
              timestamp: "2024-01-15T10:30:00Z"
              version: "v2.0.0"
              dependencies:
                database: "healthy"
                cache: "healthy"
      503:
        description: API indisponible
        body:
          application/json:
            type: common.ErrorResponse

# Endpoint de métriques
/metrics:
  description: Métriques de performance de l'API
  
  get:
    displayName: Récupérer les métriques
    description: |
      Fournit les métriques de performance de l'API au format Prometheus.
      Nécessite des permissions spéciales de monitoring.
    
    is:
      - common.oauth2Protected
      - common.traceable
    
    responses:
      200:
        description: Métriques récupérées avec succès
        body:
          text/plain:
            example: |
              # HELP api_requests_total Total number of API requests
              # TYPE api_requests_total counter
              api_requests_total{method="GET",status="200"} 1027
              api_requests_total{method="POST",status="201"} 45
